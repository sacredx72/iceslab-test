NODE_ENV=development

APP_PORT=3000
APP_HOST=0.0.0.0

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

LOG_LEVEL=info

JWT_SECRET=

REDIS_URL=redis://localhost:16379

# Public Hysteria2 UDP port advertised in subscription URIs.
# 443 by default — node operators usually run hysteria on :443/UDP.
HYSTERIA_PUBLIC_PORT=443

# ───── Xray panel-side config (slice 18) ─────
# Mirror of node-agent's XRAY_REALITY_* env. All three REALITY vars must be
# set for the panel to emit `vless://` endpoints in subscriptions.
XRAY_PUBLIC_PORT=443
XRAY_REALITY_PUBLIC_KEY=
XRAY_REALITY_SHORT_ID=
XRAY_REALITY_SNI=
XRAY_FLOW=xtls-rprx-vision
XRAY_FINGERPRINT=chrome

# Comma-separated list of frontend origins allowed to call the API.
# Production: set this to your admin UI domain (e.g. https://panel.example.com).
CORS_ORIGIN=http://localhost:5173