{
  "name": "@iceslab/panel-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "node ./node_modules/prisma/build/index.js migrate deploy",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "prestart": "node ./node_modules/prisma/build/index.js migrate deploy",
    "start": "node --env-file=../../.env dist/index.js",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate deploy",
    "demo:metrics": "tsx --env-file=../../.env scripts/demo-metrics.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/fastify": "^7.0.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@iceslab/shared": "workspace:*",
    "@peculiar/x509": "^2.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "undici": "^8.2.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
